<!DOCTYPE html>
<html>
<head>
    <title>GitHub Project Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">
</head>

<body>

<div class="container mt-4">

    <h2 class="mb-4">
        GitHub Projects Dashboard
    </h2>

    <div class="row">

        {% for repo in repositories %}

        <div class="col-md-4 mb-4">

            <div class="card h-100">

                <div class="card-body">

                    <h5 class="card-title">
                        {{ repo.name }}
                    </h5>

                    <p class="card-text">
                        {{ repo.description }}
                    </p>

                    <p>
                        <strong>Language:</strong>
                        {{ repo.language }}
                    </p>

                    <p>
                        <strong>Visibility:</strong>
                        {{ repo.visibility }}
                    </p>

                    <p>
                        <strong>Updated:</strong>
                        {{ repo.updated_at }}
                    </p>

                    <a href="{{ repo.url }}"
                       target="_blank"
                       class="btn btn-primary">
                        Open Repository
                    </a>

                </div>

            </div>

        </div>

        {% endfor %}

    </div>

</div>

</body>
</html>