# codex_real_time_agent.py
# SINGLE FILE — Real-time Burp replacement + Codex CLI analysis
# Run with: mitmproxy -s codex_real_time_agent.py --set capture_domain=abc.crm.com --set analysis_interval=30

import mitmproxy.http
import json
from datetime import datetime
import os
import subprocess
import threading
import time
from mitmproxy import ctx

OUTPUT_FILE = "captured_traffic.jsonl"
TRAFFIC_JSON = "traffic_data.json"

class CodexRealTimeAgent:
    def load(self, loader):
        loader.add_option(
            "capture_domain", str, "example.com",
            "Domain to capture (exact + all subdomains). Example: abc.crm.com"
        )
        loader.add_option(
            "analysis_interval", int, 30,
            "Seconds between automatic Codex analyses (0 = disable auto-analysis)"
        )
        self.traffic_count = 0
        self.last_analyzed = 0

        # Start background Codex analysis thread if enabled
        if ctx.options.analysis_interval > 0:
            threading.Thread(target=self.periodic_analyzer, daemon=True).start()
            print(f"[🚀 CodexAgent] Auto-analysis started every {ctx.options.analysis_interval}s")

    def response(self, flow: mitmproxy.http.HTTPFlow):
        domain = ctx.options.capture_domain.strip().lower()
        host = flow.request.host.lower()

        # Capture exact domain + all subdomains (*.abc.crm.com)
        if host == domain or host.endswith("." + domain):
            entry = {
                "timestamp": datetime.utcnow().isoformat(),
                "request": {
                    "method": flow.request.method,
                    "url": flow.request.url,
                    "headers": dict(flow.request.headers),
                    "body": flow.request.get_text() or "(binary or empty)"
                },
                "response": {
                    "status_code": flow.response.status_code,
                    "headers": dict(flow.response.headers),
                    "body": flow.response.get_text() or "(binary or empty)"
                }
            }

            with open(OUTPUT_FILE, "a", encoding="utf-8") as f:
                f.write(json.dumps(entry) + "\n")

            print(f"[✅ Captured] {flow.request.method} {flow.request.url}")
            self.traffic_count += 1

    def periodic_analyzer(self):
        """Background thread: runs Codex every X seconds ONLY when new traffic exists"""
        while True:
            time.sleep(ctx.options.analysis_interval)
            if self.traffic_count > self.last_analyzed:
                self.run_codex_analysis()
                self.last_analyzed = self.traffic_count

    def run_codex_analysis(self):
        if not os.path.exists(OUTPUT_FILE):
            return

        try:
            # Convert jsonl → clean JSON for Codex
            with open(OUTPUT_FILE, encoding="utf-8") as f:
                traffic = [json.loads(line) for line in f if line.strip()]

            if len(traffic) == 0:
                return

            with open(TRAFFIC_JSON, "w", encoding="utf-8") as f:
                json.dump(traffic, f, indent=2, ensure_ascii=False)

            prompt = f"""You are an expert application security analyst.
Analyze the attached @traffic_data.json file (LIVE real-time traffic from domain {ctx.options.capture_domain}).

Focus ONLY on:
• Broken Access Control / IDOR
• XSS, CSRF, Open Redirect
• SQL/NoSQL/Command Injection
• SSRF, Auth bypass, Session issues
• Logic flaws, Rate limiting, Business logic abuse

For EVERY finding:
- Severity (Critical / High / Medium / Low)
- Exact endpoint + evidence from traffic
- Ready-to-use PoC request (curl or full HTTP)
- Recommended fix

Be concise, actionable, and highlight anything new since the last analysis."""

            print(f"\n{'='*75}")
            print(f"🧠 Codex Real-time Analysis @ {datetime.now().strftime('%H:%M:%S')} "
                  f"({len(traffic)} requests captured)")
            print(f"{'='*75}")

            # Call Codex CLI (non-interactive)
            result = subprocess.run(
                ["codex", prompt],
                capture_output=True,
                text=True,
                timeout=120
            )

            if result.stdout.strip():
                print(result.stdout.strip())
            else:
                print("Codex returned no output (check your OpenAI quota or prompt).")

            if result.stderr.strip():
                print(f"⚠️ Codex stderr: {result.stderr.strip()}")

            print(f"{'='*75}\n")

        except subprocess.TimeoutExpired:
            print("⚠️ Codex analysis timed out (traffic too large or slow response)")
        except FileNotFoundError:
            print("❌ 'codex' command not found. Run: npm install -g @openai/codex")
        except Exception as e:
            print(f"❌ Codex analysis error: {e}")


addons = [CodexRealTimeAgent()]