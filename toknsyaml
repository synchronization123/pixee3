import os
import json
import requests
import subprocess
import shutil
from pathlib import Path
from datetime import datetime
from concurrent.futures import ThreadPoolExecutor

JIRA_URL = "https://jira.company.com"
BITBUCKET_URL = "https://bitbucket.company.com"
BITBUCKET_TOKEN = "TOKEN"

HEADERS = {"Authorization": "Bearer " + BITBUCKET_TOKEN}

BASE = Path(os.getcwd())

JIRA_FILE = BASE / ".jira.json"

CACHE_DIR = BASE / ".reviewcache"
DIFF_DIR = CACHE_DIR / "DIFF"
FILES_DIR = CACHE_DIR / "FILES"
REPO_DIR = CACHE_DIR / "REPO"

PROMPTS_DIR = BASE / "PROMPTS"

for d in [CACHE_DIR, DIFF_DIR, FILES_DIR, REPO_DIR]:
    d.mkdir(exist_ok=True)

def read_file(path):

    if not path.exists():
        return ""

    with open(path, encoding="utf8", errors="ignore") as f:
        return f.read()

def get_jiras():

    print("\nEnter Jira ID's:")

    raw = input("> ")

    jiras = [x.strip() for x in raw.split(",")]

    with open(JIRA_FILE, "w") as f:
        json.dump(jiras, f)

    return jiras

def choose_category():

    files = [f for f in os.listdir(PROMPTS_DIR) if f.endswith(".md")]

    print("\nSelect Review Category\n")

    print("1. ALL")

    for i, f in enumerate(files, start=2):
        print(i, f.replace(".md", ""))

    opt = int(input("\nOption: "))

    if opt == 1:
        return files

    return [files[opt-2]]

def fetch_prs(jira):

    url = JIRA_URL + "/rest/dev-status/latest/issue/detail"

    params = {
        "issueId": jira,
        "applicationType": "bitbucket",
        "dataType": "pullrequest"
    }

    r = requests.get(url, params=params)

    data = r.json()

    prs = []

    for detail in data.get("detail", []):

        for pr in detail.get("pullRequests", []):

            prs.append({
                "jira": jira,
                "id": pr["id"],
                "repo": pr["repository"]["slug"],
                "project": pr["repository"]["project"]["key"],
                "branch": pr["destination"]["branch"]
            })

    return prs

def group_by_branch(prs):

    grouped = {}

    for pr in prs:

        b = pr["branch"]

        if b not in grouped:
            grouped[b] = []

        grouped[b].append(pr)

    return grouped

def download_diff(pr):

    diff_path = DIFF_DIR / (str(pr["id"]) + ".diff")

    if diff_path.exists():
        return diff_path

    url = BITBUCKET_URL + "/projects/" + pr["project"] + "/repos/" + pr["repo"] + "/pull-requests/" + str(pr["id"]) + ".diff"

    r = requests.get(url, headers=HEADERS)

    with open(diff_path, "w", encoding="utf8") as f:
        f.write(r.text)

    return diff_path

def extract_files(pr, diff_path):

    folder = FILES_DIR / str(pr["id"])
    folder.mkdir(exist_ok=True)

    files = []

    with open(diff_path, "r", encoding="utf8", errors="ignore") as f:
        lines = f.readlines()

    current = None
    code = []

    for line in lines:

        if line.startswith("+++ b/"):

            if current:

                path = folder / current.replace("/", "_")

                with open(path, "w") as out:
                    out.writelines(code)

                files.append(path)

            current = line.replace("+++ b/", "").strip()
            code = []

        elif line.startswith("+") and not line.startswith("+++"):
            code.append(line[1:])

    if current:

        path = folder / current.replace("/", "_")

        with open(path, "w") as out:
            out.writelines(code)

        files.append(path)

    return files

def repo_meta(branch):
    return REPO_DIR / branch / "repo_metadata.json"

def clone_repo(pr):

    branch = pr["branch"]

    repo_path = REPO_DIR / branch

    meta_path = repo_meta(branch)

    if repo_path.exists() and meta_path.exists():

        data = json.load(open(meta_path))

        print("\nRepository already downloaded")
        print("Project:", data["projectkey"])
        print("Repo:", data["repo"])
        print("Downloaded:", data["downloadeddate"])

        print("\n1 Use existing repo")
        print("2 Download latest\n")

        c = input("Option: ")

        if c == "1":
            return repo_path

        shutil.rmtree(repo_path)

    repo_url = BITBUCKET_URL + "/scm/" + pr["project"] + "/" + pr["repo"] + ".git"

    subprocess.run([
        "git",
        "clone",
        "--depth",
        "1",
        "--branch",
        branch,
        repo_url,
        str(repo_path)
    ])

    meta_data = {
        "projectkey": pr["project"],
        "repo": pr["repo"],
        "downloadeddate": datetime.now().strftime("%d-%m-%Y")
    }

    with open(meta_path, "w") as f:
        json.dump(meta_data, f, indent=4)

    return repo_path

def build_prompt(jira, pr, files, repo, prompt_files):

    category = ""

    for p in prompt_files:
        category += read_file(PROMPTS_DIR / p) + "\n\n"

    code = ""

    for f in files:

        with open(f, encoding="utf8", errors="ignore") as x:

            code += "\nFILE:" + str(f) + "\n"
            code += x.read() + "\n"

    prompt = f"""

SECURE PYTHON APPLICATION CODE REVIEW

JIRA ISSUE
{jira}

PULL REQUEST
{pr["id"]}

TARGET BRANCH
{pr["branch"]}

CHANGED CODE
{code}

REPOSITORY CONTEXT
{repo}

TASK

Perform a comprehensive security analysis of this Python application.

1 Identify user-controlled sources
2 Identify dangerous sinks
3 Identify sanitization
4 Trace source-to-sink flows
5 Use repository context for cross-file analysis
6 Determine exploitability

OUTPUT

Vulnerability Type
File
Code
Source
Sink
Sanitizer
Data Flow
Exploit Scenario
Severity

"""

    return category + prompt

def run_codex(prompt):

    result = subprocess.run(
        ["codex", "exec", prompt],
        capture_output=True,
        text=True
    )

    return result.stdout

def analyze_pr(pr, repo, prompts):

    print("\nAnalyzing PR", pr["id"], "(", pr["jira"], ")")

    diff = download_diff(pr)

    files = extract_files(pr, diff)

    prompt = build_prompt(pr["jira"], pr, files, repo, prompts)

    result = run_codex(prompt)

    return pr["jira"], result

def cleanup():

    print("\nCleaning temporary files\n")

    if JIRA_FILE.exists():
        with open(JIRA_FILE, "w") as f:
            json.dump([], f)

    for f in DIFF_DIR.glob("*"):
        f.unlink()

    for d in FILES_DIR.glob("*"):
        shutil.rmtree(d)

    print("Cleanup done\n")

def main():

    jiras = get_jiras()

    print("\nFetching pull requests\n")

    prs = []

    for j in jiras:
        prs.extend(fetch_prs(j))

    grouped = group_by_branch(prs)

    print("\nBranches Found\n")

    branches = list(grouped.keys())

    for i, b in enumerate(branches, start=1):
        print(i, b)

    opt = int(input("\nSelect branch: "))

    branch = branches[opt-1]

    selected_prs = grouped[branch]

    repo = clone_repo(selected_prs[0])

    prompts = choose_category()

    print("\nStarting Analysis\n")

    results = {}

    with ThreadPoolExecutor(max_workers=3) as exe:

        futures = [exe.submit(analyze_pr, pr, repo, prompts) for pr in selected_prs]

        for f in futures:

            jira, res = f.result()

            if jira not in results:
                results[jira] = []

            results[jira].append(res)

    print("\n========== FINAL RESULT ==========\n")

    for j, r in results.items():

        print("\nJIRA:", j, "\n")

        for x in r:
            print(x)
            print("\n---------------------------\n")

    cleanup()

    input("Press Enter to close")

if __name__ == "__main__":
    main()