import os
import javalang
from collections import defaultdict, deque

SOURCES = ["getParameter","getHeader","nextLine"]
SINKS = ["executeQuery","executeUpdate","prepareStatement"]

class VirtualRepo:

    def __init__(self):
        self.files = {}

    def load(self, path):

        for root,_,files in os.walk(path):

            for f in files:

                if f.endswith((".java",".jsp")):

                    full=os.path.join(root,f)

                    try:
                        with open(full,"r",errors="ignore") as fp:
                            self.files[full]=fp.read()
                    except:
                        pass


class SymbolResolver:

    def __init__(self,repo):

        self.repo=repo
        self.class_map={}
        self.method_map={}

    def build(self):

        for path,code in self.repo.files.items():

            if not path.endswith(".java"):
                continue

            try:
                tree=javalang.parse.parse(code)
            except:
                continue

            for _,node in tree.filter(javalang.tree.ClassDeclaration):
                self.class_map[node.name]=path

            for _,node in tree.filter(javalang.tree.MethodDeclaration):
                self.method_map[node.name]=path


class CallGraph:

    def __init__(self):
        self.graph=defaultdict(set)

    def build(self,repo,resolver):

        for path,code in repo.files.items():

            if not path.endswith(".java"):
                continue

            try:
                tree=javalang.parse.parse(code)
            except:
                continue

            for _,node in tree.filter(javalang.tree.MethodInvocation):

                method=node.member

                if method in resolver.method_map:

                    target=resolver.method_map[method]

                    self.graph[path].add(target)


class FlowResolver:

    def __init__(self,graph):
        self.graph=graph

    def resolve(self,entry):

        visited=set()
        flow=[]
        q=deque([entry])

        while q:

            node=q.popleft()

            if node in visited:
                continue

            visited.add(node)
            flow.append(node)

            for nxt in self.graph.get(node,[]):
                q.append(nxt)

        return flow


class TaintAnalyzer:

    def run(self,repo):

        tainted=set()
        findings=[]

        for path,code in repo.files.items():

            for i,line in enumerate(code.splitlines()):

                for src in SOURCES:

                    if src in line:

                        parts=line.split("=")

                        if len(parts)>1:

                            var=parts[0].split()[-1]
                            tainted.add(var)

                            findings.append(
                                f"SOURCE | {path}:{i+1} | {line.strip()}"
                            )

                for var in list(tainted):

                    if var in line:

                        for sink in SINKS:

                            if sink in line:

                                findings.append(
                                  f"SINK | {path}:{i+1} | {line.strip()}"
                                )

        return findings


class ContextBuilder:

    def build(self,flow,findings):

        text="SECURITY FLOW\n\nFLOW\n"

        for f in flow:
            text+=f" → {os.path.basename(f)}\n"

        text+="\nEVIDENCE\n"

        for f in findings:
            text+=f+"\n"

        return text


def main():

    repo=VirtualRepo()
    repo.load("./repo")

    resolver=SymbolResolver(repo)
    resolver.build()

    graph=CallGraph()
    graph.build(repo,resolver)

    entry=list(repo.files.keys())[0]

    flow=FlowResolver(graph.graph).resolve(entry)

    findings=TaintAnalyzer().run(repo)

    context=ContextBuilder().build(flow,findings)

    print(context)


if __name__=="__main__":
    main()