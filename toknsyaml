import streamlit as st
from docx import Document
from openai import OpenAI
import os
import io

# Configure page
st.set_page_config(page_title="Meeting Notes Generator", layout="wide")
st.title("Meeting Notes Generator")
st.markdown("Upload a DOCX file containing meeting conversations to generate structured notes.")

# File uploader
uploaded_file = st.file_uploader("Choose a DOCX file", type="docx")

if uploaded_file is not None:
    # Display loading modal/spinner
    with st.spinner("Processing document and generating notes... This may take a moment."):
        
        # Extract text from DOCX
        doc = Document(io.BytesIO(uploaded_file.read()))
        full_text = "\n".join([paragraph.text for paragraph in doc.paragraphs if paragraph.text.strip()]).strip()
        
        if not full_text:
            st.error("No text found in the document.")
        else:
            # Initialize OpenAI client (assumes API key is set in env)
            client = OpenAI(api_key=os.getenv("OPENAI_API_KEY"))
            
            if not client.api_key:
                st.error("OpenAI API key not found. Set OPENAI_API_KEY environment variable.")
            else:
                # Craft prompt for structured notes
                prompt = f"""
                You are an expert meeting note taker. Analyze the following DOCX conversation transcript and generate structured meeting notes in Markdown format.
                
                Transcript:
                {full_text}
                
                Output exactly in this structure (use Markdown for tables and headings):
                
                # Meeting Notes
                
                ## Date
                [Extract the meeting date from the transcript or infer the most relevant one. Format: YYYY-MM-DD]
                
                ## Attendees
                - [List all unique participants mentioned, e.g., - John Doe]
                
                ## Meeting Summary
                [A concise 3-5 sentence summary of the key points, decisions, and overall purpose of the meeting.]
                
                ## Topics Discussed
                | Topic | Brief Description |
                |-------|-------------------|
                [Row for each main topic, e.g., | Topic 1 | Short desc |
                
                ## Detailed Discussions
                [For each topic, provide a detailed table. Repeat sections as needed for multiple topics.]
                
                ### [Topic Name]
                | Discussion Details | Person(s) Involved | Outcome | Action Items | Notes (Dates, etc.) |
                |--------------------|--------------------|---------|--------------|---------------------|
                [Rows for key exchanges under this topic, e.g., | Summary of points raised | John Doe, Jane Smith | Agreement reached | Assign task to Bob by due date | Due: 2026-03-15 |
                
                Use 'N/A' where info is not applicable. Ensure tables are complete and parseable. If multiple topics, add more ### sections.
                """
                
                # Call OpenAI API
                try:
                    response = client.chat.completions.create(
                        model="gpt-4o-mini",  # Or use "gpt-3.5-turbo" for cost savings
                        messages=[{"role": "system", "content": "You are a precise and structured note generator."},
                                  {"role": "user", "content": prompt}],
                        temperature=0.3,
                        max_tokens=2000
                    )
                    
                    generated_notes = response.choices[0].message.content
                    
                    # Display the notes
                    st.markdown("### Generated Meeting Notes")
                    st.markdown(generated_notes)
                    
                    # Optional: Download button for notes
                    st.download_button(
                        label="Download Notes as MD",
                        data=generated_notes,
                        file_name="meeting_notes.md",
                        mime="text/markdown"
                    )
                    
                except Exception as e:
                    st.error(f"Error generating notes: {str(e)}. Check your API key and quota.")

# Footer
st.markdown("---")
st.markdown("Powered by Streamlit and OpenAI. Ensure your DOCX contains clear conversation text for best results.")