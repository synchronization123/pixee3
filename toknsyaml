**Step 2: Process Single Jira (copy-paste and edit jira_id; run for each one-by-one):**  
```python
jira_id = 'PROJ-123'  # Edit to your first Jira ID from list
print(f"\n--- Processing {jira_id} ---")
try:
    prs = get_jira_issue_prs(jira_id)
    if not prs:
        row_idx = df[df['Jira Id'] == jira_id].index[0]
        df.loc[row_idx, 'Suggestion'] = 'No PRs Found'
        df.loc[row_idx, 'Notes'] = 'No associated PRs; skip review.'
        df.loc[row_idx, 'Comment'] = 'N/A'
        df.to_excel(path, index=False)
        print("Updated: No PRs.")
    else:
        vuln_summary = []
        all_changes_low_risk = True
        for pr in prs:
            try:
                diff = get_bitbucket_pr_diff(pr['pr_id'])
                if not diff:
                    commits = get_bitbucket_pr_commits(pr['pr_id'])
                    diff = '\n'.join([c.get('diff', '') for c in commits if c.get('diff')])
                if len(diff) > 2000: diff = diff[:2000] + '\n[Truncated - flag for manual]'
                
                # Security analysis (simple regex/keyword scan + logic)
                risks = []
                if any(kw in diff.lower() for kw in ['password=', 'secret=', 'api_key=']): risks.append('Hard-coded secrets (High, OWASP A07)')
                if 'sql' in diff.lower() and 'parameter' not in diff.lower(): risks.append('Potential SQLi in query (High, OWASP A03)')
                if 'input' in diff.lower() and 'escape' not in diff.lower() and 'sanitize' not in diff.lower(): risks.append('Unvalidated input (Med, OWASP A07)')
                if 'crypto' in diff.lower() or 'hash' in diff.lower(): risks.append('Crypto impl - manual check needed (Med, OWASP A02)')
                if len(risks) > 0 or len(diff) > 1000 or 'auth' in diff.lower():
                    all_changes_low_risk = False
                vuln_summary.append(f"PR {pr['pr_id']}: {pr['title'][:50]}... Risks: {', '.join(risks) if risks else 'None (Low)'}. Key changes: {diff[:200]}...")
            except Exception as e:
                vuln_summary.append(f"PR {pr['pr_id']}: Error fetching diff - {str(e)}")
        
        # Decision
        if not all_changes_low_risk:
            suggestion = 'Yes - Manual Security Testing Required'
            notes = 'High/med risks or complex changes detected; verify manually (OWASP refs above).'
        else:
            suggestion = 'No - Automated Review Sufficient'
            notes = 'Low/cosmetic changes only; no security-sensitive code touched.'
        
        row_idx = df[df['Jira Id'] == jira_id].index[0]
        df.loc[row_idx, 'Suggestion'] = suggestion
        df.loc[row_idx, 'Notes'] = notes
        df.loc[row_idx, 'Comment'] = '; '.join(vuln_summary)
        df.to_excel(path, index=False)
        print(f"Updated {jira_id}: {suggestion}. Vulns: {df.loc[row_idx, 'Comment'][:150]}...")
except Exception as e:
    print(f"Error for {jira_id}: {str(e)}. Set to manual review.")
    row_idx = df[df['Jira Id'] == jira_id].index[0]
    df.loc[row_idx, 'Suggestion'] = 'Error - Review Manually'
    df.loc[row_idx, 'Notes'] = str(e)
    df.to_excel(path, index=False)
```
