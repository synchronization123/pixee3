import requests
import subprocess

JIRA_BASE = "https://jira.crm.com"
BITBUCKET_BASE = "https://bitbucket.crm.com"

JIRA_TOKEN = "YOUR_JIRA_TOKEN"
BITBUCKET_TOKEN = "YOUR_BITBUCKET_TOKEN"

JIRA_HEADERS = {
    "Authorization": f"Bearer {JIRA_TOKEN}",
    "Accept": "application/json"
}

BB_HEADERS = {
    "Authorization": f"Bearer {BITBUCKET_TOKEN}",
    "Accept": "application/json"
}


def get_issue_id(jira_key):

    url = f"{JIRA_BASE}/rest/api/2/issue/{jira_key}?fields=id"

    r = requests.get(url, headers=JIRA_HEADERS)

    if r.status_code != 200:
        print(f"Failed to fetch Jira {jira_key}")
        return None

    return r.json()["id"]


def get_pull_requests(issue_id):

    url = f"{JIRA_BASE}/rest/dev-status/1.0/issue/detail"

    params = {
        "issueId": issue_id,
        "applicationType": "stash",
        "dataType": "pullrequest"
    }

    r = requests.get(url, headers=JIRA_HEADERS, params=params)

    prs = []

    if r.status_code == 200:

        data = r.json()

        for pr in data["detail"][0]["pullRequests"]:

            if pr["status"] != "DECLINED":

                prs.append({
                    "id": pr["id"],
                    "repo": pr["repositorySlug"],
                    "project": pr["project"]["key"]
                })

    return prs


def get_added_lines(project, repo, pr_id):

    url = f"{BITBUCKET_BASE}/rest/api/projects/{project}/repos/{repo}/pull-requests/{pr_id}.diff"

    r = requests.get(url, headers=BB_HEADERS)

    if r.status_code != 200:
        return ""

    added_lines = []

    for line in r.text.split("\n"):

        if line.startswith("+") and not line.startswith("+++"):
            added_lines.append(line[1:])

    return "\n".join(added_lines)


def save_code_file(jira, pr_id, code):

    filename = f"{jira}_PR{pr_id}_added_code.txt"

    with open(filename, "w", encoding="utf-8") as f:
        f.write(code)

    return filename


def run_codex_review(file):

    prompt = f"""
You are a senior Application Security engineer.

Review the code snippets in this file.

Tasks:
1. Summarize what functionality was added
2. Identify security vulnerabilities
3. Highlight risky patterns
4. Provide severity
5. Provide remediation
"""

    cmd = f'codex exec "{prompt}" < {file}'

    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)

    return result.stdout


def main():

    jira_input = input("Enter Jira IDs (comma separated): ")

    jira_list = [j.strip() for j in jira_input.split(",")]

    for jira in jira_list:

        print(f"\nProcessing {jira}")

        issue_id = get_issue_id(jira)

        if not issue_id:
            continue

        prs = get_pull_requests(issue_id)

        if not prs:
            print("No active PRs found")
            continue

        for pr in prs:

            pr_id = pr["id"]

            code = get_added_lines(pr["project"], pr["repo"], pr_id)

            if not code.strip():
                print("No added code")
                continue

            file = save_code_file(jira, pr_id, code)

            review = run_codex_review(file)

            print("\n==== SECURITY REVIEW ====")
            print(review)


if __name__ == "__main__":
    main()